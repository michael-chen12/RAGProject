# Supabase — get from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# AI Configuration (Google Gemini)
# ============================================================================
# Sign up: https://aistudio.google.com/
# Get API key: Click "Get API Key" → "Create API Key"
# Free tier: 1,500 chat requests/day, 1,000 embedding requests/day
# Uses: Gemini 2.0 Flash (chat) + text-embedding-004 (768-dim embeddings)

GOOGLE_API_KEY=your-gemini-api-key-here

# ============================================================================
# Application Configuration
# ============================================================================

# Application URL (used for redirects and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (optional) — for rate limiting and caching
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Logging (optional) — controls log verbosity
LOG_LEVEL=info
